# Server
PORT=4000
NODE_ENV=development

# CORS - comma separated list of allowed origins, or "*" for all (dev only)
CORS_ORIGIN=http://localhost:3000

# Supabase
# Find these in your Supabase project: Settings -> API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use the SERVICE ROLE key (not anon) - this server bypasses RLS intentionally.
# NEVER expose this key to a frontend/browser context.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# API key required in the X-API-Key header for all write operations (POST/PATCH/DELETE).
# Defaults to "graphone-dev-key" if unset - change this for anything beyond local dev.
API_KEY=graphone-dev-key
